# OVRIQ miljøkonfiguration — kopiér til .env og udfyld. COMMIT ALDRIG .env.
POSTGRES_PASSWORD=skift-mig-til-noget-langt-og-tilfaeldigt
OVRIQ_DOMAIN=api.ovriq.com
# Uden DATABASE_URL bruges fil-journal (kun dev):
# OVRIQ_DATABASE_URL=postgres://ovriq:...@db:5432/ovriq
# OVRIQ_JOURNAL_PATH=./data/journal.jsonl

# PayPal (Gate 2) — start ALTID i sandbox. Se PAYPAL_SETUP.md
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
# OVRIQ_PUBLIC_URL=https://api.ovriq.xyz
# OVRIQ_ALLOW_LIVE_PAYMENTS=yes   # KUN efter Gate 2 PASS + advokat-OK
